window/size/viewport_height=810

[dotnet]

project/assembly_name="Stewart Prealpha"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogue_manager/plugin.cfg", "res://addons/vector_display_2d/plugin.cfg")

