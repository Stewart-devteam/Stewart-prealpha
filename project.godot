config_version=5

[application]

config/name="Stewart Prealpha"
config/description="Stewart es un RPG de fantasía, aventura y comedia que combina estética furry, aventura medieval y cultura colombiana."
config/version="0.1"
config/tags=PackedStringArray("gdd")
run/main_scene="uid://cacld0petm7tj"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="uid://b6368ena3wquo"

[autoload]

DialogueManager="*res://addons/dialogue_manager/dialogue_manager.gd"
FlagsManager="*uid://cta06ediohss"
GameConstants="*uid://bafho2r335kbv"
MusicManager="*uid://dv2bd61v3fdf0"
PlayerStats="*uid://b1ei5cqblmk3s"
SceneManager="*uid://c7qpxa5bjkyo6"

[display]

